{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "api/index.js",
      "framework": "express",
      "routePrefix": "/api",
      "includeFiles": [
        "backend/**"
      ]
    }
  }
}
